{
  "name": "claude-agent-app",
  "version": "1.1.0",
  "description": "Control panel for claude-agent — web UI + Telegram/Discord bridges",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:all": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && node scripts/electron-build.cjs",
    "electron:build:mac": "npm run build && node scripts/electron-build.cjs --mac",
    "electron:build:win": "npm run build && node scripts/electron-build.cjs --win",
    "electron:build:linux": "npm run build && node scripts/electron-build.cjs --linux"
  },
  "build": {
    "appId": "com.claude-world.agent",
    "productName": "Claude Agent",
    "npmRebuild": false,
    "asar": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "files": [
      "**/*",
      "!client/**",
      "!scripts/**",
      "!release/**",
      "!*.config.*",
      "!tsconfig.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": null
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-world/claude-agent.git"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "discord.js": "^14.16.0",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "tsx": "^4.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "react-use-websocket": "^4.9.0",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
